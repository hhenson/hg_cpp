{
  "version": 6,
  "configurePresets": [
    {
      "name": "cpp",
      "displayName": "Native C++ Release",
      "description": "Clean native acceptance build using the repository Python environment for PyArrow discovery.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-cpp",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "HGRAPH_BUILD_PYTHON_BINDINGS": "OFF",
        "HGRAPH_ENABLE_PYTHON_USER_NODES": "OFF",
        "HGRAPH_ENABLE_IDE_PYTHON_HEADER_HINTS": "OFF",
        "HGRAPH_USE_PYARROW_ARROW": "ON",
        "HGRAPH_FETCH_SIMDJSON": "ON",
        "HGRAPH_FETCH_DATE": "ON",
        "HGRAPH_WARNINGS_AS_ERRORS": "ON",
        "Python_EXECUTABLE": "${sourceDir}/.venv/bin/python"
      }
    },
    {
      "name": "python-user-nodes",
      "displayName": "Python User Nodes",
      "description": "Enable HGRAPH_ENABLE_PYTHON_USER_NODES for IDE indexing and Python bridge development.",
      "binaryDir": "${sourceDir}/cmake-build-python-user-nodes",
      "cacheVariables": {
        "HGRAPH_ENABLE_PYTHON_USER_NODES": "ON",
        "Python_EXECUTABLE": "${sourceDir}/.venv/bin/python",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "cpp",
      "configurePreset": "cpp"
    },
    {
      "name": "python-user-nodes",
      "configurePreset": "python-user-nodes"
    }
  ],
  "testPresets": [
    {
      "name": "cpp",
      "configurePreset": "cpp",
      "output": {
        "outputOnFailure": true
      },
      "environment": {
        "CTEST_PARALLEL_LEVEL": "16"
      }
    }
  ]
}
